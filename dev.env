## Redis commander

REDIS_COMMANDER_REDIS_HOST=redis
REDIS_COMMANDER_USER=admin
REDIS_COMMANDER_PASSWORD=redisadmin

## NATS
NATS_PORT=4222
NATS_MONITOR_PORT=8222
NATS_USER=client_user
NATS_PASSWORD=client_pass

## S3
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# App

## Postgres
SF_APP_POSTGRES_CONNECTION_STRING=postgresql://localhost:5432/shared_finances
SF_APP_POSTGRES_DB=shared_finances
